{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "vendor": {
    "$comment": [
      "Initialisation part for PZC. You can edit it.",
      "Call 'initarc'/'initap'/'initcmp' and 'clearcmp' to update paths in configurePresets part.",
      "Call 'savepcmp' to save this file."
    ],
    "pzc": {
      "cmpSourceDir": "@PZC_CMP_SOURCE_DIR@",
      "cmpBuildDir": "@PZC_CMP_BUILD_DIR@",
      "cmpInstallDir": "@PZC_CMP_INSTALL_DIR@",
      @PZC_CMP_OTHER_VAR@
      "cmpDependencies": [],
      "pzcPresetsVersion": [7,6,0]
    }
  },
  "include": ["@CMP_BUILD_DIR@/generated_default_@CMP_PROJECT_NAME@_@CMP_DIR_BUILD_TYPE@.json"],
  "configurePresets": [
    {
      "name": "@CMP_BUILD_TYPE@",
      "description": "Build @CMP_PROJECT_NAME@",
      "inherits" : ["PZC_@CMP_BUILD_TYPE@"],

      "$comment": "You can copy variables from PZC preset to override it.",
      "cacheVariables": {
      }
    },
    {
      "name": "@CMP_BUILD_TYPE@_gpu",
      "description": "Build @CMP_PROJECT_NAME@ for GPU",
      "inherits" : ["PZC_@CMP_BUILD_TYPE@_gpu"],

      "$comment": "You can copy variables from PZC preset to override it.",
      "cacheVariables": {
      }
    }
  ],
  "$comment": [
    "Available PZC @variables@ to use in this file:",
    "",
    "CMP_PROJECT :                       Name of the project (if detected, otherwise 'generic')     (example: hdf5)",
    "CMP_PROJECT_NAME :                  Name of the repo folder                                    (example: hdf5)",
    "CMP_SOURCE_DIR :                    Location of the sources                                    (example: /home/user/work/hdf5)",
    "CMP_BUILD_DIR :                     Location of the build dir                                  (example: /home/user/build/build_hdf5/check_hdf5mpi)",
    "CMP_INSTALL_DIR :                   Location of the install dir                                (example: /home/user/install/install_hdf5/check_hdf5mpi)",
    "CMP_DIR_BUILD_TYPE :                Folder to build and install project                        (example: check_hdf5mpi)",
    "CMP_BUILD_TYPE :                    Build type (debug/check/release)                           (example: check)",
    "CMP_VARIANT :                       Variant name                                               (example: hdf5mpi)",
    "CMP_CMAKE_BUILD_TYPE :              CMake-compatible build type (Debug/RelWithDebInfo/Release) (example: RelWithDebInfo)",
    "CMP_CMAKE_GENERATOR :               Name of the generator (Ninja or Unix Makefiles)            (example: Ninja)",
    "CMP_CMAKE_C_CXX_COMPILER_LAUNCHER : Path of the compiler launcher (ccache ou null)             (example: /usr/bin/ccache)",
    "CMP_CMAKE_LINKER_TYPE :             Name of the linker (mold or null)                          (example: /usr/bin/mold)",
    "CMP_CMAKE_C_COMPILER :              Path of the C compiler                                     (example: /usr/bin/gcc)",
    "CMP_CMAKE_CXX_COMPILER :            Path of the C++ compiler                                   (example: /usr/bin/g++)",
    "CMP_GPU_HOST_COMPILER :             Path of the C++ compiler used with GPU compiler            (example: /usr/bin/g++13)",
    "CMP_CMAKE_PREFIX_PATH :             (paths or empty string)                                    (example: /home/user/install/install_mpich/check)",
    "CMP_CMAKE_CUDA_COMPILER :           Path of the CUDA compiler (path or null)                   (example: /usr/bin/nvcc)",
    "CMP_CMAKE_CUDA_FLAGS :              Flags for the CUDA compiler (flags or null)                (example: null)",
    "CMP_CMAKE_CUDA_ARCHITECTURES :      Target architectures (arch or null)                        (example: 89)",
    "CMP_CMAKE_SYCL_COMPILER :           Path of the SYCL compiler (path or null)                   (example: /usr/bin/adaptivecpp)",
    "CMP_ARCANE_BUILD_TYPE :             Arcane-compatible build type (Debug/Check/Release)         (example: Check)",
    "CMP_ARCANE_CXX_SYCL_FLAGS :         Flags passed to SYCL (Arcane-specific)                     (example: --acpp-targets=cuda:sm_89)",
    "CMP_ARCANE_ACCELERATOR_MODE :       (CUDA/SYCL)                                                (example: CUDA)"
  ]
}
