{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "@CMP_BUILD_TYPE@",
      "description": "Build @PROJECT_NAME@ @TYPE_BUILD_DIR@",
      "binaryDir": "@CMP_BUILD_DIR@",
      "installDir": "@CMP_INSTALL_DIR@",
      "generator": "@PZC_CMAKE_GENERATOR@",
      "cacheVariables": {
        @PZC_CMAKE_CXX_COMPILER_LAUNCHER@
        @PZC_CMAKE_C_COMPILER_LAUNCHER@
        @PZC_CMAKE_LINKER_TYPE@
        "CMAKE_BUILD_TYPE": "@PZC_CMAKE_BUILD_TYPE@",
        "CMAKE_C_COMPILER": "@PZC_C_COMPILER@",
        "CMAKE_CXX_COMPILER": "@PZC_CXX_COMPILER@",
        "CMAKE_PREFIX_PATH": "@ARCANE_INSTALL_DIR@"
      }
    },
    {
      "name": "@CMP_BUILD_TYPE@_gpu",
      "description": "Build @PROJECT_NAME@ @TYPE_BUILD_DIR@ for GPU",
      "binaryDir": "@CMP_BUILD_DIR@",
      "installDir": "@CMP_INSTALL_DIR@",
      "generator": "@PZC_CMAKE_GENERATOR@",
      "cacheVariables": {
        @PZC_CMAKE_CXX_COMPILER_LAUNCHER@
        @PZC_CMAKE_C_COMPILER_LAUNCHER@
        @PZC_CMAKE_LINKER_TYPE@
        @_PZC_CMAKE_GPU_COMPILER@
        @_PZC_CMAKE_GPU_FLAGS@
        @_PZC_CMAKE_GPU_ARCH@
        "CMAKE_BUILD_TYPE": "@PZC_CMAKE_BUILD_TYPE@",
        "CMAKE_C_COMPILER": "@PZC_C_COMPILER@",
        "CMAKE_CXX_COMPILER": "@PZC_GPU_HOST_COMPILER@",
        "CMAKE_PREFIX_PATH": "@ARCANE_INSTALL_DIR@"
      }
    }
  ]
}
