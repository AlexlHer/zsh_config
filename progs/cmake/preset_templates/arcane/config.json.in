{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "$comment": [
    "File generated by PZC. Don't edit it. You can edit user file with 'editpcmp' command."
  ],
  "configurePresets": [
    {
      "name": "PZC_@CMP_BUILD_TYPE@",
      "description": "Build Arcane",
      "hidden" : true,
      "binaryDir": "@CMP_BUILD_DIR@",
      "installDir": "@CMP_INSTALL_DIR@",
      "generator": "@CMP_CMAKE_GENERATOR@",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "@CMP_CMAKE_PREFIX_PATH@",
        "CMAKE_LINKER_TYPE": "@CMP_CMAKE_LINKER_TYPE@",
        "CMAKE_C_COMPILER_LAUNCHER": "@CMP_CMAKE_C_CXX_COMPILER_LAUNCHER@",
        "CMAKE_CXX_COMPILER_LAUNCHER": "@CMP_CMAKE_C_CXX_COMPILER_LAUNCHER@",
        "CMAKE_BUILD_TYPE": "@CMP_CMAKE_BUILD_TYPE@",
        "CMAKE_C_COMPILER": "@CMP_CMAKE_C_COMPILER@",
        "CMAKE_CXX_COMPILER": "@CMP_CMAKE_CXX_COMPILER@",
        "ARCANE_BUILD_TYPE": "@CMP_ARCANE_BUILD_TYPE@",
        "ARCCORE_BUILD_MODE": "@CMP_ARCANE_BUILD_TYPE@",
        "ARCCORE_CXX_STANDARD": "23",
        "BIG_TEST": "TRUE",
        "ARCANEFRAMEWORK_BUILD_COMPONENTS": "Arcane"
      }
    },
    {
      "name": "PZC_@CMP_BUILD_TYPE@_gpu",
      "description": "Build Arcane for GPU",
      "hidden" : true,
      "inherits" : ["PZC_@CMP_BUILD_TYPE@"],
      "binaryDir": "@CMP_BUILD_DIR@",
      "installDir": "@CMP_INSTALL_DIR@",
      "generator": "@CMP_CMAKE_GENERATOR@",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "@CMP_GPU_HOST_COMPILER@",
        "ARCCORE_CXX_STANDARD": "20",
        "ARCANE_ACCELERATOR_MODE": "@CMP_ARCANE_ACCELERATOR_MODE@",
        "CMAKE_CUDA_COMPILER": "@CMP_CMAKE_CUDA_COMPILER@",
        "CMAKE_CUDA_FLAGS": "@CMP_CMAKE_CUDA_FLAGS@",
        "CMAKE_CUDA_ARCHITECTURES": "@CMP_CMAKE_CUDA_ARCHITECTURES@",
        "CMAKE_SYCL_COMPILER": "@CMP_CMAKE_SYCL_COMPILER@",
        "ARCANE_CXX_SYCL_FLAGS": "@CMP_ARCANE_CXX_SYCL_FLAGS@"
      }
    }
  ]
}
